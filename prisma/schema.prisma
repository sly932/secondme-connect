generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp", schema: "extensions"), vector]
}

model User {
  id             String                 @id @default(cuid())
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  secondmeId     String                 @unique
  accessToken    String
  refreshToken   String
  tokenExpiry    DateTime
  name           String
  avatar         String?
  bio            String?
  shades         Json?
  softmemory     Json?
  embedding      Unsupported("vector")?
  credits        Int                    @default(100)
  totalOrders    Int                    @default(0)
  totalEarnings  Int                    @default(0)
  apiKey         String?                @unique
  orderMode      OrderMode              @default(MANUAL)
  autoTopN       Int                    @default(1)
  isNpc          Boolean                @default(false)
  autoJoinGame   Boolean                @default(false)
  boundUserId    String?
  boundUser      User?                  @relation("npcBinding", fields: [boundUserId], references: [id])
  boundNpcs      User[]                 @relation("npcBinding")
  lastDailyCredit DateTime?
  creditLogs     CreditLog[]
  gamePlayers    GamePlayer[]
  createdRooms   GameRoom[]             @relation("roomCreator")
  publishedTasks Task[]                 @relation("publisher")
  receivedTasks  Task[]                 @relation("worker")
  posts          Post[]                 @relation("PostAuthor")
  comments       Comment[]              @relation("CommentAuthor")

  @@index([boundUserId])
  @@map("users")
}

model Task {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  type        TaskType
  category    TaskCategory?
  status      TaskStatus    @default(MATCHING)
  description String
  result      String?
  resultUrl   String?
  creditCost  Int
  startedAt   DateTime?
  completedAt DateTime?
  timeoutMs   Int?
  publisherId String
  workerId    String?
  publisher   User          @relation("publisher", fields: [publisherId], references: [id])
  worker      User?         @relation("worker", fields: [workerId], references: [id])

  @@index([publisherId])
  @@index([workerId])
  @@index([status])
  @@map("tasks")
}

model CreditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  amount    Int
  balance   Int
  reason    String
  taskId    String?
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("credit_logs")
}

model GameRoom {
  id           String       @id @default(cuid())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  gameType     GameType
  maxPlayers   Int          @default(4)
  minChips     Int          @default(10)
  totalRounds  Int          @default(5)
  status       RoomStatus   @default(PLAYING)
  currentRound Int          @default(0)
  creatorId    String
  players      GamePlayer[]
  creator      User         @relation("roomCreator", fields: [creatorId], references: [id])
  rounds       GameRound[]

  @@index([creatorId])
  @@index([status])
  @@map("game_rooms")
}

model GamePlayer {
  id        String       @id @default(cuid())
  roomId    String
  userId    String
  position  Int
  isCreator Boolean      @default(false)
  isAI      Boolean      @default(false)
  chips     Int
  status    PlayerStatus @default(ACTIVE)
  actions   GameAction[]
  room      GameRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])

  @@unique([roomId, position])
  @@index([roomId])
  @@map("game_players")
}

model GameRound {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  roomId         String
  roundNumber    Int
  status         RoundStatus  @default(IN_PROGRESS)
  pot            Int          @default(0)
  communityCards Json?
  dealerHand     Json?
  winnerId       String?
  resultLog      Json?
  roundSnapshot  Json?
  actions        GameAction[]
  room           GameRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, roundNumber])
  @@index([roomId])
  @@map("game_rounds")
}

model GameAction {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  roundId   String
  playerId  String
  action    String
  amount    Int?
  cards     Json?
  message   String?
  player    GamePlayer @relation(fields: [playerId], references: [id])
  round     GameRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([roundId])
  @@map("game_actions")
}

model Post {
  id        String    @id @default(cuid())
  content   String
  authorId  String
  author    User      @relation("PostAuthor", fields: [authorId], references: [id])
  comments  Comment[]
  createdAt DateTime  @default(now())

  @@index([authorId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, authorId])
  @@index([postId])
  @@map("comments")
}

enum OrderMode {
  AUTO
  MANUAL
}

enum TaskType {
  CONSULT
  MARKETPLACE
}

enum TaskCategory {
  WRITING
  PAINTING
}

enum GameType {
  BLACKJACK
  TEXAS_HOLDEM
}

enum RoomStatus {
  PLAYING
  COMPLETED
  CANCELLED
}

enum PlayerStatus {
  ACTIVE
  FOLDED
  BUSTED
  LEFT
}

enum RoundStatus {
  IN_PROGRESS
  COMPLETED
}

enum TaskStatus {
  MATCHING
  PENDING
  EVALUATING
  ACCEPTED
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}
