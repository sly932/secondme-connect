# ============================================
# SecondMe OAuth2
# 在 SecondMe 开发者后台创建应用后获取
# https://develop-docs.second.me/zh/docs/authentication/oauth2
# ============================================

# 格式: UUID (例: 21039e2e-xxxx-xxxx-xxxx-abc5e3e33dfd)
# 来源: SecondMe 开发者后台 → 应用管理 → Client ID
SECONDME_CLIENT_ID=

# 格式: 长字符串
# 来源: SecondMe 开发者后台 → 应用管理 → Client Secret
SECONDME_CLIENT_SECRET=

# OAuth 回调地址，本地开发用 localhost，部署后改成实际域名
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ============================================
# Supabase
# 在 https://supabase.com 创建项目后，
# 进入 Project Settings → API 页面获取
# ============================================

# 格式: https://<project-id>.supabase.co
SUPABASE_URL=

# 格式: eyJhbGciOiJIUzI1NiIs... (JWT)
# 来源: Project Settings → API → anon public key
SUPABASE_ANON_KEY=

# 格式: eyJhbGciOiJIUzI1NiIs... (JWT)
# 来源: Project Settings → API → service_role key (⚠️ 不要暴露到前端)
SUPABASE_SERVICE_ROLE_KEY=

# 格式: postgresql://postgres:<password>@db.<project-id>.supabase.co:5432/postgres
# 来源: Project Settings → Database → Connection string → URI
DATABASE_URL=

# ============================================
# OpenRouter (用于调用 OpenAI Embedding 模型)
# 在 https://openrouter.ai 注册后获取
# ============================================

# 格式: sk-or-v1-xxxxxxxxxxxxxxxx
# 来源: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Base URL，默认 https://openrouter.ai/api/v1
# 如果用其他兼容 OpenAI 的服务可以改这里
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Embedding 模型名称，默认 openai/text-embedding-3-small
# 其他选项如: openai/text-embedding-3-large, openai/text-embedding-ada-002
EMBEDDING_MODEL=openai/text-embedding-3-small

# ============================================
# NextAuth
# ============================================

# 本地开发用 localhost，部署后改成实际域名
NEXTAUTH_URL=http://localhost:3000

# 格式: 随机字符串 (至少 32 位)
# 生成方法: 终端运行 `openssl rand -base64 32`
NEXTAUTH_SECRET=

# ============================================
# App Token 加密密钥 (用于生成 ck-xxx 格式的 API Key)
# ============================================

# 格式: 随机字符串 (至少 32 位)
# 生成方法: 终端运行 `openssl rand -base64 32`
APP_TOKEN_SECRET=